# ========================================
# 智慧农业平台 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ========================================

# ---- 数据库 ----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartfarm_dev
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=dev123

# ---- Redis ----
SPRING_DATA_REDIS_HOST=localhost

# ---- MQTT ----
MQTT_BROKER=tcp://localhost:1883

# ---- JWT ----
JWT_SECRET=change-me-in-production-at-least-256-bits-long

# ---- AI 大模型（通义千问） ----
AI_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_LLM_API_KEY=sk-your-qwen-api-key-here
AI_LLM_MODEL=qwen-plus

# ---- AI 降级模型（DeepSeek，可选） ----
AI_FALLBACK_ENABLED=false
AI_FALLBACK_API_URL=https://api.deepseek.com/v1/chat/completions
AI_FALLBACK_API_KEY=
AI_FALLBACK_MODEL=deepseek-chat

# ---- 微信 ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=
