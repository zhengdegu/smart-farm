page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}
.container { padding: 20rpx; }
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.btn-primary {
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  color: #fff;
  border-radius: 24rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-danger {
  background: linear-gradient(135deg, #D32F2F, #E53935);
  color: #fff;
  border-radius: 24rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-success { background: #E8F5E9; color: #2E7D32; }
.tag-danger { background: #fef0f0; color: #D32F2F; }
.tag-warning { background: #fdf6ec; color: #F57C00; }
.tag-info { background: #f0f2f5; color: #909399; }
