page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}
.container { padding: 20rpx; }
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.btn-primary {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-danger {
  background: linear-gradient(135deg, #fa5151, #e04040);
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-success { background: #e8f8ee; color: #07c160; }
.tag-danger { background: #fef0f0; color: #fa5151; }
.tag-warning { background: #fdf6ec; color: #e6a23c; }
.tag-info { background: #f0f2f5; color: #909399; }
