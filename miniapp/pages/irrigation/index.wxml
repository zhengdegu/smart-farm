<view class="container">
  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="btn-primary" bindtap="onManualIrrigate">手动灌溉</view>
    <view class="btn-danger" bindtap="onEmergencyStop">紧急停止</view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{tab==='rules'?'active':''}}" bindtap="onTabChange" data-tab="rules">灌溉规则</view>
    <view class="tab-item {{tab==='history'?'active':''}}" bindtap="onTabChange" data-tab="history">执行记录</view>
  </view>

  <!-- 规则列表 -->
  <block wx:if="{{tab==='rules'}}">
    <view class="card rule-card" wx:for="{{rules}}" wx:key="id">
      <view class="rule-header">
        <text class="rule-name">{{item.name}}</text>
        <switch checked="{{item.enabled}}" color="#07c160" bindchange="onToggleRule" data-id="{{item.id}}" />
      </view>
      <view class="rule-info">
        <text>类型: {{item.ruleType==='THRESHOLD'?'阈值触发':'定时执行'}}</text>
        <text>阀门: {{item.deviceId}}</text>
      </view>
      <view class="rule-detail" wx:if="{{item.ruleType==='THRESHOLD'}}">
        <text>湿度 < {{item.thresholdLow}}% 开阀，> {{item.thresholdHigh}}% 关阀</text>
      </view>
      <view class="rule-detail" wx:if="{{item.ruleType==='SCHEDULE'}}">
        <text>定时: {{item.cronExpression}}，时长 {{item.durationMin}} 分钟</text>
      </view>
    </view>
    <view class="empty" wx:if="{{!rules.length}}"><text>暂无规则</text></view>
  </block>

  <!-- 执行记录 -->
  <block wx:if="{{tab==='history'}}">
    <view class="card cmd-card" wx:for="{{commands}}" wx:key="cmdId">
      <view class="cmd-header">
        <text class="cmd-device">{{item.deviceId}}</text>
        <view class="tag {{item.status==='EXECUTED'?'tag-success':item.status==='FAILED'?'tag-danger':'tag-warning'}}">{{item.status}}</view>
      </view>
      <view class="cmd-info">
        <text>{{item.action==='OPEN_VALVE'?'开阀':'关阀'}}</text>
        <text>{{item.triggeredBy}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{!commands.length}}"><text>暂无记录</text></view>
  </block>
</view>
