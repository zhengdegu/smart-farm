.page-container {
  padding-bottom: 32rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  padding: 32rpx 32rpx 16rpx;
}

/* ===== 子标签切换 ===== */
.tab-switch {
  display: flex;
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.tab-switch-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #757575;
  transition: all 0.15s;
}
.tab-switch-item.active {
  background: #2E7D32;
  color: #fff;
  font-weight: 600;
}

/* ===== 图表卡片 ===== */
.chart-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.chart-placeholder {
  height: 320rpx;
  background: linear-gradient(180deg, rgba(46,125,50,0.08), rgba(46,125,50,0.02));
  border-radius: 16rpx;
  display: flex;
  align-items: flex-end;
  padding: 0 16rpx 16rpx;
  gap: 12rpx;
}
.chart-placeholder.chart-small {
  height: 240rpx;
}
.chart-bar {
  flex: 1;
  background: linear-gradient(180deg, #4CAF50, #2E7D32);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 40rpx;
}
.chart-line {
  height: 240rpx;
  background: linear-gradient(180deg, rgba(46,125,50,0.06), transparent);
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}
.chart-line::after {
  content: '';
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #2E7D32, #4CAF50, #2E7D32);
  border-radius: 2rpx;
}

/* ===== 节水率卡片 ===== */
.water-save-card {
  margin: 24rpx 32rpx;
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  border-radius: 24rpx;
  padding: 48rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.ws-value {
  font-size: 96rpx;
  font-weight: 800;
}
.ws-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}
.ws-sub {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 16rpx;
}

/* ===== 作物卡片 ===== */
.crop-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.crop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.crop-name {
  font-size: 32rpx;
  font-weight: 700;
}
.crop-stage-badge {
  background: #E8F5E9;
  color: #2E7D32;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.crop-date {
  font-size: 26rpx;
  color: #757575;
}

/* ===== 阶段进度条 ===== */
.stage-progress {
  display: flex;
  gap: 4rpx;
  margin: 24rpx 0;
}
.stage-step {
  flex: 1;
  height: 12rpx;
  border-radius: 6rpx;
  background: #E0E0E0;
}
.stage-step.done {
  background: #2E7D32;
}
.stage-step.current {
  background: #4CAF50;
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.stage-labels {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #757575;
}

/* ===== 参数网格 ===== */
.crop-params {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}
.param-item {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}
.param-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #2E7D32;
}
.param-label {
  font-size: 22rpx;
  color: #757575;
}
