<!-- 渐变色头部 -->
<view class="home-header">
  <view class="home-header-top">
    <view>
      <text class="base-name">🌱 {{baseName}}</text>
    </view>
    <view class="header-right">
      <view class="alert-badge" wx:if="{{alertCount > 0}}">{{alertCount}}</view>
      <view class="base-switch">切换 ▾</view>
    </view>
  </view>
  <view class="weather-row">
    <text>☀️ {{weather.temp}}</text>
    <text>湿度 {{weather.humidity}}</text>
    <text>{{weather.wind}}</text>
  </view>
</view>

<!-- 4个数据卡片 2x2 网格 -->
<view class="data-cards">
  <view class="data-card {{item.type}}" wx:for="{{cards}}" wx:key="label">
    <view class="card-icon">{{item.icon}}</view>
    <view class="card-value-row">
      <text class="card-value">{{item.value}}</text>
      <text class="card-unit">{{item.unit}}</text>
    </view>
    <view class="card-label">{{item.label}}</view>
    <view class="card-status {{item.status}}">{{item.statusText}}</view>
  </view>
</view>

<!-- AI 建议横幅 -->
<view class="advice-banner">
  <view class="advice-icon">🌿</view>
  <view class="advice-content">
    <view class="advice-stage">{{advice.stage}}</view>
    <view class="advice-text">{{advice.text}}</view>
  </view>
</view>

<!-- 今日汇总栏 -->
<view class="today-summary">
  <view class="sum-item">
    <view class="sum-val">{{summary.irrigationCount}}</view>
    <view class="sum-label">今日灌溉(次)</view>
  </view>
  <view class="sum-item">
    <view class="sum-val">{{summary.totalDuration}}</view>
    <view class="sum-label">总时长(分钟)</view>
  </view>
  <view class="sum-item">
    <view class="sum-val">{{summary.waterUsage}}</view>
    <view class="sum-label">用水量(吨)</view>
  </view>
</view>

<!-- AI 浮动按钮 -->
<view class="ai-float-btn" bindtap="onOpenChat">问问小农 🤖</view>

<!-- 固定底部操作栏 -->
<view class="action-bar">
  <view class="action-btn btn-start" bindtap="onStartIrrigation">💧 开始灌溉</view>
  <view class="action-btn btn-stop">⏹ 停止</view>
  <view class="action-btn btn-emergency" bindtap="onEmergencyStop">🚨 急停</view>
</view>

<!-- AI 对话面板 -->
<chat-panel show="{{showChat}}" bind:close="onCloseChat" />

<!-- 灌溉模态框 -->
<view class="modal-overlay {{showIrrigationModal ? 'show' : ''}}" catchtap="onCloseIrrigationModal">
  <view class="modal-box" catchtap="">
    <view class="modal-title">💧 开始灌溉</view>
    <view class="m-form-group">
      <text class="m-form-label">选择阀门</text>
      <picker mode="selector" range="{{valveOptions}}" bindchange="onValveChange">
        <view class="m-form-select">{{irrigationForm.valve}}</view>
      </picker>
    </view>
    <view class="m-form-group">
      <text class="m-form-label">灌溉时长（分钟）</text>
      <input class="m-form-input" type="number" value="{{irrigationForm.duration}}" bindinput="onDurationInput" />
    </view>
    <view class="m-form-group">
      <text class="m-form-label">目标湿度（%）</text>
      <input class="m-form-input" type="number" value="{{irrigationForm.targetHumidity}}" bindinput="onHumidityInput" />
    </view>
    <view class="m-btn m-btn-primary" bindtap="onConfirmIrrigation">确认灌溉</view>
    <view class="m-btn m-btn-cancel" bindtap="onCloseIrrigationModal">取消</view>
  </view>
</view>

<!-- 急停确认模态框 -->
<view class="modal-overlay {{showEmergencyModal ? 'show' : ''}}" catchtap="onCloseEmergencyModal">
  <view class="modal-box" catchtap="">
    <view class="emergency-modal-content">
      <view class="emergency-icon">🚨</view>
      <view class="emergency-title">紧急停止</view>
      <view class="emergency-desc">确认关闭所有灌溉阀门？此操作将立即停止所有正在进行的灌溉任务。</view>
      <view class="m-btn m-btn-danger" bindtap="onConfirmEmergency">确认急停</view>
      <view class="m-btn m-btn-cancel" bindtap="onCloseEmergencyModal">取消</view>
    </view>
  </view>
</view>
