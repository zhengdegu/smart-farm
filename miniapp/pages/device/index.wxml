<view class="page-container">
  <view class="page-title">设备管理</view>

  <!-- 设备汇总栏 -->
  <view class="device-summary">
    <view class="dev-sum-item">
      <view class="dev-sum-val online">{{summary.online}}</view>
      <view class="dev-sum-label">在线</view>
    </view>
    <view class="dev-sum-item">
      <view class="dev-sum-val offline">{{summary.offline}}</view>
      <view class="dev-sum-label">离线</view>
    </view>
    <view class="dev-sum-item">
      <view class="dev-sum-val fault">{{summary.fault}}</view>
      <view class="dev-sum-label">故障</view>
    </view>
  </view>

  <!-- 按类型分组设备列表 -->
  <block wx:for="{{groups}}" wx:key="title">
    <view class="section-title">{{item.title}} ({{item.count}})</view>
    <view
      class="device-item"
      wx:for="{{item.devices}}"
      wx:for-item="device"
      wx:key="id"
      bindtap="onDeviceTap"
      data-device="{{device}}"
    >
      <view class="dev-icon-wrap {{device.iconBg}}">{{device.icon}}</view>
      <view class="dev-info">
        <view class="dev-name">{{device.name}}</view>
        <view class="dev-meta">{{device.meta}}</view>
      </view>
      <view class="status-dot {{device.status}}"></view>
    </view>
  </block>

  <view class="empty" wx:if="{{!loading && groups.length === 0}}">
    <text>暂无设备</text>
  </view>
</view>

<!-- 设备详情浮层 -->
<view class="detail-overlay {{showDetail ? 'show' : ''}}" wx:if="{{showDetail}}">
  <view class="detail-header">
    <view class="detail-back" bindtap="onCloseDetail">‹</view>
    <text>{{detailDevice.name}}</text>
  </view>
  <view class="detail-body">
    <!-- 设备基本信息 -->
    <view class="detail-card">
      <view class="detail-device-name">{{detailDevice.name}}</view>
      <view class="detail-device-meta">位置：{{detailDevice.meta}}</view>
      <view class="detail-device-meta">
        状态：<text class="{{detailDevice.status === 'online' ? 'text-green' : 'text-red'}}">{{detailInfo.status}}</text>
      </view>
    </view>

    <!-- 24小时趋势图表占位 -->
    <view class="detail-card">
      <view class="detail-card-title">24小时趋势</view>
      <view class="detail-chart">
        <view class="dbar" style="height:40%"></view>
        <view class="dbar" style="height:55%"></view>
        <view class="dbar" style="height:50%"></view>
        <view class="dbar" style="height:65%"></view>
        <view class="dbar" style="height:60%"></view>
        <view class="dbar" style="height:70%"></view>
        <view class="dbar" style="height:55%"></view>
        <view class="dbar" style="height:45%"></view>
        <view class="dbar" style="height:50%"></view>
        <view class="dbar" style="height:60%"></view>
        <view class="dbar" style="height:65%"></view>
        <view class="dbar" style="height:58%"></view>
      </view>
    </view>

    <!-- 信息网格 -->
    <view class="detail-info-grid">
      <view class="detail-info-item">
        <view class="detail-info-val">{{detailInfo.currentValue}}</view>
        <view class="detail-info-label">当前值</view>
      </view>
      <view class="detail-info-item">
        <view class="detail-info-val">{{detailInfo.status}}</view>
        <view class="detail-info-label">运行状态</view>
      </view>
      <view class="detail-info-item">
        <view class="detail-info-val">{{detailInfo.onlineRate}}</view>
        <view class="detail-info-label">在线率(30天)</view>
      </view>
      <view class="detail-info-item">
        <view class="detail-info-val">{{detailInfo.lastReport}}</view>
        <view class="detail-info-label">最后上报</view>
      </view>
    </view>
  </view>
</view>
