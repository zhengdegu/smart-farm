<view class="login-page">
  <view class="login-header">
    <text class="login-icon">🌱</text>
    <text class="login-title">智慧农业平台</text>
    <text class="login-subtitle">设施温室智能灌溉管理系统</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <input class="form-input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" />
    </view>
    <view class="form-item">
      <input class="form-input" placeholder="请输入密码" password="true" value="{{password}}" bindinput="onPasswordInput" />
    </view>
    <view class="btn-primary login-btn" bindtap="onLogin">
      <text wx:if="{{!loading}}">登 录</text>
      <text wx:else>登录中...</text>
    </view>
  </view>
</view>
