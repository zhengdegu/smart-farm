.login-page { min-height: 100vh; background: linear-gradient(180deg, #07c160 0%, #06ad56 40%, #f5f5f5 40%); display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.login-header { text-align: center; margin-bottom: 80rpx; }
.login-icon { font-size: 96rpx; display: block; margin-bottom: 20rpx; }
.login-title { font-size: 44rpx; font-weight: 700; color: #fff; display: block; }
.login-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 12rpx; }
.login-form { width: 85%; background: #fff; border-radius: 24rpx; padding: 48rpx 36rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1); }
.form-item { margin-bottom: 32rpx; }
.form-input { border: 1rpx solid #e0e0e0; border-radius: 12rpx; padding: 24rpx; font-size: 30rpx; }
.login-btn { margin-top: 16rpx; }
