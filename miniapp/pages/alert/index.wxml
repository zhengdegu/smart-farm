<view class="page-container">
  <view class="page-title">告警中心</view>

  <!-- AI 巡检 -->
  <view class="ai-patrol-section" wx:if="{{patrolLogs.length > 0}}">
    <view class="section-title">🤖 AI 巡检</view>
    <view class="patrol-item {{item.severity === 'WARNING' ? 'patrol-warning' : item.severity === 'CRITICAL' ? 'patrol-critical' : ''}}" wx:for="{{patrolLogs}}" wx:key="id">
      <view class="patrol-icon">{{item.typeIcon}}</view>
      <view class="patrol-content">
        <view class="patrol-finding">{{item.findingSummary}}</view>
        <view class="patrol-meta">
          <text class="patrol-severity {{item.severity}}">{{item.severityLabel}}</text>
          <text class="patrol-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 告警统计 -->
  <view class="alert-stats">
    <text class="alert-stat">今日告警 <text class="stat-bold">{{stats.today}}</text> 条</text>
    <text class="alert-stat">待处理 <text class="stat-bold stat-red">{{stats.pending}}</text> 条</text>
  </view>

  <!-- 筛选标签组 -->
  <scroll-view class="alert-filter" scroll-x="true" enable-flex="true">
    <view
      class="filter-chip {{activeFilter === item.key ? 'active' : ''}}"
      wx:for="{{filters}}"
      wx:key="key"
      bindtap="onFilterChange"
      data-key="{{item.key}}"
    >{{item.label}}</view>
  </scroll-view>

  <!-- 告警列表 -->
  <view
    class="alert-item"
    wx:for="{{filteredAlerts}}"
    wx:key="id"
    bindtap="onAlertTap"
    data-alert="{{item}}"
  >
    <view class="alert-level-badge {{item.levelClass}}">{{item.level}}</view>
    <view class="alert-content">
      <view class="alert-title">{{item.title}}</view>
      <view class="alert-device">{{item.device}}</view>
      <view class="alert-time">{{item.time}}</view>
      <view class="alert-action" wx:if="{{item.status === 'pending'}}">点击处理 →</view>
      <view class="alert-resolved" wx:if="{{item.status === 'resolved'}}">✓ 已处理</view>
    </view>
  </view>

  <view class="empty" wx:if="{{filteredAlerts.length === 0}}">
    <text>暂无告警</text>
  </view>
</view>

<!-- 告警详情浮层 -->
<view class="detail-overlay {{showDetail ? 'show' : ''}}" wx:if="{{showDetail}}">
  <view class="detail-header">
    <view class="detail-back" bindtap="onCloseDetail">‹</view>
    <text>告警详情</text>
  </view>
  <view class="detail-body">
    <view class="detail-card">
      <view class="detail-level-row">
        <view class="alert-level-badge {{detailAlert.levelClass}}">{{detailAlert.level}}</view>
        <text class="detail-title">{{detailAlert.title}}</text>
      </view>
      <view class="detail-info-row">
        <text>📍 {{detailAlert.device}}</text>
      </view>
      <view class="detail-info-row">
        <text>🕐 {{detailAlert.time}}</text>
      </view>
      <view class="detail-desc">{{detailAlert.content}}</view>
      <view class="detail-values" wx:if="{{detailAlert.currentValue}}">
        <view class="detail-value-item">
          <text class="detail-value-label">当前值</text>
          <text class="detail-value-text">{{detailAlert.currentValue}}</text>
        </view>
        <view class="detail-value-item">
          <text class="detail-value-label">阈值</text>
          <text class="detail-value-text">{{detailAlert.threshold}}</text>
        </view>
      </view>
    </view>
    <view class="m-btn m-btn-primary" wx:if="{{detailAlert.status === 'pending'}}" bindtap="onAcknowledge">确认处理</view>
  </view>
</view>
