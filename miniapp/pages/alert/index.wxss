.page-container {
  padding-bottom: 32rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  padding: 32rpx 32rpx 16rpx;
}

/* ===== 告警统计 ===== */
.alert-stats {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx 24rpx;
}
.alert-stat {
  font-size: 26rpx;
  color: #757575;
}
.stat-bold {
  font-weight: 700;
  color: #212121;
}
.stat-red {
  color: #D32F2F;
}

/* ===== 筛选标签 ===== */
.alert-filter {
  display: flex;
  gap: 12rpx;
  padding: 0 32rpx 24rpx;
  white-space: nowrap;
}
.filter-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  white-space: nowrap;
  background: #fff;
  color: #757575;
  border: 1rpx solid #E0E0E0;
}
.filter-chip.active {
  background: #2E7D32;
  color: #fff;
  border-color: #2E7D32;
}

/* ===== 告警列表项 ===== */
.alert-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  background: #fff;
  margin: 0 32rpx 16rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  gap: 24rpx;
}
.alert-level-badge {
  min-width: 64rpx;
  height: 40rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.alert-level-badge.l1 { background: #D32F2F; }
.alert-level-badge.l2 { background: #F57C00; }
.alert-level-badge.l3 { background: #FBC02D; }
.alert-content {
  flex: 1;
}
.alert-title {
  font-size: 28rpx;
  font-weight: 600;
}
.alert-device {
  font-size: 24rpx;
  color: #757575;
  margin-top: 4rpx;
}
.alert-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}
.alert-action {
  font-size: 24rpx;
  color: #2E7D32;
  font-weight: 600;
  margin-top: 12rpx;
}
.alert-resolved {
  font-size: 24rpx;
  color: #4CAF50;
  margin-top: 8rpx;
}

/* ===== 告警详情浮层 ===== */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F5F5;
  z-index: 150;
  display: none;
  flex-direction: column;
  overflow: hidden;
}
.detail-overlay.show {
  display: flex;
}
.detail-header {
  height: 88rpx;
  background: #2E7D32;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  gap: 20rpx;
  flex-shrink: 0;
}
.detail-back {
  font-size: 40rpx;
  padding: 0 8rpx;
}
.detail-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}
.detail-level-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-title {
  font-size: 32rpx;
  font-weight: 700;
}
.detail-info-row {
  font-size: 26rpx;
  color: #757575;
  margin-bottom: 8rpx;
}
.detail-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #212121;
  margin-top: 24rpx;
}
.detail-values {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}
.detail-value-item {
  flex: 1;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}
.detail-value-label {
  font-size: 22rpx;
  color: #757575;
  display: block;
}
.detail-value-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2E7D32;
  display: block;
  margin-top: 4rpx;
}

/* ===== 按钮 ===== */
.m-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}
.m-btn-primary {
  background: #2E7D32;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 160rpx 0;
  color: #999;
}

/* ===== AI 巡检分区 ===== */
.ai-patrol-section {
  margin: 0 32rpx 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 16rpx;
}
.patrol-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
.patrol-item.patrol-warning {
  background: #FFF8E1;
  border-left: 6rpx solid #F57C00;
}
.patrol-item.patrol-critical {
  background: #FFEBEE;
  border-left: 6rpx solid #D32F2F;
}
.patrol-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  width: 56rpx;
  text-align: center;
}
.patrol-content {
  flex: 1;
  min-width: 0;
}
.patrol-finding {
  font-size: 26rpx;
  color: #212121;
  line-height: 1.5;
  word-break: break-all;
}
.patrol-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}
.patrol-severity {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}
.patrol-severity.INFO {
  background: #E3F2FD;
  color: #1565C0;
}
.patrol-severity.WARNING {
  background: #FFF3E0;
  color: #E65100;
}
.patrol-severity.CRITICAL {
  background: #FFEBEE;
  color: #C62828;
}
.patrol-time {
  font-size: 22rpx;
  color: #9E9E9E;
}
