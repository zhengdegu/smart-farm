/* ===== 个人资料头部 ===== */
.profile-header {
  text-align: center;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
}
.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  font-size: 64rpx;
  border: 6rpx solid rgba(255,255,255,0.4);
}
.profile-name {
  font-size: 36rpx;
  font-weight: 700;
}
.profile-role {
  font-size: 26rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}
.profile-base {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}

/* ===== 菜单组 ===== */
.menu-group {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
  gap: 24rpx;
  font-size: 30rpx;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 40rpx;
  width: 56rpx;
  text-align: center;
}
.menu-label {
  flex: 1;
}
.menu-aux {
  font-size: 26rpx;
  color: #757575;
}
.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* ===== 退出登录 ===== */
.logout-section {
  padding: 40rpx 32rpx;
}
.logout-btn {
  background: linear-gradient(135deg, #D32F2F, #E53935);
  color: #fff;
  border-radius: 24rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}
