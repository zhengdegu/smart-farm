<!-- 个人资料头部 -->
<view class="profile-header">
  <view class="avatar">{{profile.avatar}}</view>
  <view class="profile-name">{{profile.name}}</view>
  <view class="profile-role">{{profile.role}}</view>
  <view class="profile-base">{{profile.base}}</view>
</view>

<!-- 菜单组 -->
<view class="menu-group" wx:for="{{menuGroups}}" wx:key="index">
  <view
    class="menu-item"
    wx:for="{{item.items}}"
    wx:for-item="menuItem"
    wx:key="key"
    bindtap="onMenuTap"
    data-key="{{menuItem.key}}"
  >
    <text class="menu-icon">{{menuItem.icon}}</text>
    <text class="menu-label">{{menuItem.label}}</text>
    <text class="menu-aux" wx:if="{{menuItem.aux}}">{{menuItem.aux}}</text>
    <text class="menu-arrow">›</text>
  </view>
</view>

<!-- 退出登录 -->
<view class="logout-section" wx:if="{{isLoggedIn}}">
  <view class="logout-btn" bindtap="onLogout">退出登录</view>
</view>
